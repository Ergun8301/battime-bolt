# Battime — variables d'environnement
#
# Supabase. Laissez VIDE pour utiliser la base de production par défaut
# (valeurs de repli codées dans lib/supabase.ts → aucune régression).
#
# Le jour où l'on veut une base de STAGING pour les previews (afin que les
# tests ne touchent plus les vraies données), créez un 2e projet Supabase
# (offre gratuite possible) puis définissez ces variables côté hébergeur
# (Netlify) sur le contexte « Deploy preview » uniquement :
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
